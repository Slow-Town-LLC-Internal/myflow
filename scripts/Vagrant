Vagrant.configure("2") do |config|
  config.vm.box = "ubuntu/jammy64"

  # Shared folders
  config.vm.synced_folder "~/Projects", "/projects"

  config.vm.network "private_network", type: "dhcp"
  config.vm.network "forwarded_port", guest: 3000, host: 3000  # for default Next.js
  config.vm.network "forwarded_port", guest: 8000, host: 8000  # for Python servers
  config.vm.network "forwarded_port", guest: 5173, host: 5173  # for Vite
  config.vm.network "forwarded_port", guest: 4000, host: 4000  # for other dev servers
  config.vm.network "forwarded_port", guest: 5432, host: 5432  # PostgreSQL default port

  config.vm.provider "virtualbox" do |v|
    v.memory = 2048
    v.cpus = 2
    v.customize ["setextradata", :id, "VBoxInternal2/EfiGraphicsResolution", "1920x1080"]
    # Add these lines for clipboard
    v.customize ["modifyvm", :id, "--clipboard", "bidirectional"]
    v.customize ["modifyvm", :id, "--draganddrop", "bidirectional"]

  end

  config.vm.provision "shell", privileged: false, inline: <<-SHELL
    curl -O https://raw.githubusercontent.com/Slow-Town-LLC-Internal/myflow/main/scripts/install.sh
    chmod +x install.sh
    ./install.sh
  SHELL
end
